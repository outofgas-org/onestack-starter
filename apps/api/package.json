{
	"name": "@onestack/api",
	"private": true,
	"scripts": {
		"dev": "PORT=5201 bun --hot src/index.ts",
		"start": "bun src/index.ts",
		"prisma:generate": "prisma generate",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check": "bun run lint && bun run typecheck",
		"generate:version": "sh scripts/gen-version.sh"
	},
	"dependencies": {
		"@hono/zod-openapi": "^0.19.10",
		"@onestack/shared": "workspace:*",
		"@prisma/adapter-pg": "^7.4.1",
		"@prisma/client": "^7.4.1",
		"@privy-io/server-auth": "^1.32.5",
		"@scalar/hono-api-reference": "^0.10.19",
		"dotenv": "^17.3.1",
		"hono": "^4.12.5",
		"pg": "^8.18.0",
		"pino": "^10.3.1",
		"prisma": "^7.4.1",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "latest",
		"pino-pretty": "^13.1.3",
		"typescript": "^5.9.3"
	}
}
